    <!-- PROGRAMACIÓN / MOTORES DE SINCRONIZACIÓN E INTERACCIÓN -->
    <script>
        const totalSlides = 10;
        let activeIndex = 0;
        const viewport = document.getElementById('carousel-viewport');
        const dots = document.getElementById('carousel-dots').children;

        // Estados de Interacciones Nativas
        let liked = false;
        let saved = false;
        let reposted = false;
        let captionExpanded = false;

        // 1. ANIMACIÓN DEL LIKE (CORAZÓN)
        function toggleLike() {
            liked = !liked;
            const btn = document.getElementById('heart-btn');
            const icon = btn.querySelector('i');
            const countSpan = document.getElementById('heart-count');
            
            if (liked) {
                icon.className = "fa-solid fa-heart text-red-500 animate-heart-pop";
                countSpan.innerText = "523 mil";
                countSpan.classList.add('text-red-500');
            } else {
                icon.className = "fa-regular fa-heart";
                countSpan.innerText = "522 mil";
                countSpan.classList.remove('text-red-500');
            }
        }

        // DOBLE CLIC (DOUBLE TAP LIKE)
        function triggerDoubleTapLike() {
            const heartOverlay = document.getElementById('big-heart-overlay');
            
            heartOverlay.classList.remove('animate-big-heart');
            void heartOverlay.offsetWidth; // Truco de reflow para reiniciar CSS
            heartOverlay.classList.add('animate-big-heart');

            if (!liked) {
                toggleLike();
            }
        }

        // 2. ANIMACIÓN DE COMPARTIR / REPOST
        function toggleRepost() {
            reposted = !reposted;
            const btn = document.getElementById('repost-btn');
            const icon = btn.querySelector('i');
            const countSpan = document.getElementById('repost-count');
            
            icon.classList.add('animate-repost');
            setTimeout(() => {
                icon.classList.remove('animate-repost');
            }, 650);

            if (reposted) {
                icon.classList.add('text-emerald-500');
                countSpan.innerText = "1.611";
                countSpan.classList.add('text-emerald-500');
            } else {
                icon.classList.remove('text-emerald-500');
                countSpan.innerText = "1.610";
                countSpan.classList.remove('text-emerald-500');
            }
        }

        // 3. ANIMACIÓN DE GUARDAR
        function toggleSave() {
            saved = !saved;
            const btn = document.getElementById('save-btn');
            const icon = btn.querySelector('i');
            
            icon.classList.add('animate-bookmark');
            setTimeout(() => {
                icon.classList.remove('animate-bookmark');
            }, 450);

            if (saved) {
                icon.className = "fa-solid fa-bookmark text-white";
                showToast("¡Publicación guardada!");
            } else {
                icon.className = "fa-regular fa-bookmark";
            }
        }

        // 4. LEYENDA EXPANDIBLE (MÁS / MENOS)
        function toggleCaption() {
            captionExpanded = !captionExpanded;
            const shortSpan = document.getElementById('caption-short');
            const fullSpan = document.getElementById('caption-full');
            const moreBtn = document.getElementById('caption-more-btn');
            
            if (captionExpanded) {
                shortSpan.classList.add('hidden');
                fullSpan.classList.remove('hidden');
                moreBtn.innerText = "menos";
            } else {
                shortSpan.classList.remove('hidden');
                fullSpan.classList.add('hidden');
                moreBtn.innerText = "más";
            }
        }

        // Alterar el slide visible
        function changeSlide(index) {
            if (index < 0 || index >= totalSlides) return;
            activeIndex = index;
            
            const slideWidth = viewport.clientWidth;
            viewport.scrollTo({
                left: slideWidth * index,
                behavior: 'smooth'
            });

            updateUI();
        }

        // Evento de scroll dinámico
        function handleScroll() {
            const slideWidth = viewport.clientWidth;
            const computedIndex = Math.round(viewport.scrollLeft / slideWidth);
            if (computedIndex !== activeIndex && computedIndex >= 0 && computedIndex < totalSlides) {
                activeIndex = computedIndex;
                updateUI();
            }
        }

        function prevIndex() {
            return (activeIndex - 1 + totalSlides) % totalSlides;
        }

        function nextIndex() {
            return (activeIndex + 1) % totalSlides;
        }

        // Actualizar interfaz y sincronizar botones con seguridad de nulos (Null Safe)
        function updateUI() {
            const indicator = document.getElementById('slide-indicator');
            if (indicator) {
                indicator.innerText = `${(activeIndex + 1).toString().padStart(2, '0')} / ${totalSlides.toString().padStart(2, '0')}`;
            }
            
            for (let i = 0; i < dots.length; i++) {
                if (dots[i]) {
                    if (i === activeIndex) {
                        dots[i].classList.add('custom-active-dot');
                    } else {
                        dots[i].classList.remove('custom-active-dot');
                    }
                }
            }

            const quickButtons = document.getElementsByClassName('slide-nav-btn');
            for (let i = 0; i < quickButtons.length; i++) {
                if (quickButtons[i]) {
                    if (i === activeIndex) {
                        quickButtons[i].className = "slide-nav-btn bg-bogota text-asfalto font-bold text-xs py-2 rounded-lg transition-all border border-transparent shadow hover:scale-105 active:scale-95";
                    } else {
                        quickButtons[i].className = "slide-nav-btn bg-white/5 hover:bg-white/10 text-white font-bold text-xs py-2 rounded-lg transition-all border border-transparent active:scale-95";
                    }
                }
            }
        }

        // Notificación flotante rápida
        function showToast(message) {
            const toast = document.getElementById('toast');
            const toastText = document.getElementById('toast-text');
            if (!toast || !toastText) return;
            
            toastText.innerText = message;
            toast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-10');
            toast.classList.add('opacity-100', 'translate-y-0');
            
            setTimeout(() => {
                toast.classList.remove('opacity-100', 'translate-y-0');
                toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-10');
            }, 3000);
        }

        // Listeners de teclas de dirección (izquierda / derecha)
        document.addEventListener('keydown', function(event) {
            if (event.key === 'ArrowRight') {
                changeSlide(nextIndex());
            } else if (event.key === 'ArrowLeft') {
                changeSlide(prevIndex());
            }
        });

        window.addEventListener('resize', () => {
            changeSlide(activeIndex);
        });

        window.onload = function() {
            updateUI();
        }
    </script>
</body>
</html>
